{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "delivery-created.v1.schema.json",
    "title": "DeliveryCreatedV1",
    "allOf": [
        {
            "$ref": "./event-envelope.v1.schema.json"
        },
        {
            "type": "object",
            "properties": {
                "eventType": {
                    "const": "DeliveryCreated"
                },
                "schemaVersion": {
                    "const": "v1"
                },
                "producer": {
                    "const": "delivery-service"
                },
                "data": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "orderId",
                        "deliveryId"
                    ],
                    "properties": {
                        "orderId": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "deliveryId": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                }
            }
        }
    ]
}