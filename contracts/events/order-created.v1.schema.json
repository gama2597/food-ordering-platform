{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "order-created.v1.schema.json",
    "title": "OrderCreatedV1",
    "allOf": [
        {
            "$ref": "./event-envelope.v1.schema.json"
        },
        {
            "type": "object",
            "properties": {
                "eventType": {
                    "const": "OrderCreated"
                },
                "schemaVersion": {
                    "const": "v1"
                },
                "producer": {
                    "const": "order-service"
                },
                "data": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "orderId",
                        "userId",
                        "restaurantId",
                        "items",
                        "totalAmount",
                        "currency"
                    ],
                    "properties": {
                        "orderId": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "userId": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "restaurantId": {
                            "type": "string",
                            "format": "uuid"
                        },
                        "items": {
                            "type": "array",
                            "minItems": 1,
                            "items": {
                                "type": "object",
                                "additionalProperties": false,
                                "required": [
                                    "menuItemId",
                                    "name",
                                    "quantity",
                                    "unitPrice"
                                ],
                                "properties": {
                                    "menuItemId": {
                                        "type": "string",
                                        "format": "uuid"
                                    },
                                    "name": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "quantity": {
                                        "type": "integer",
                                        "minimum": 1
                                    },
                                    "unitPrice": {
                                        "type": "number",
                                        "minimum": 0
                                    }
                                }
                            }
                        },
                        "totalAmount": {
                            "type": "number",
                            "minimum": 0
                        },
                        "currency": {
                            "type": "string",
                            "minLength": 3,
                            "maxLength": 3,
                            "examples": [
                                "PEN"
                            ]
                        }
                    }
                }
            }
        }
    ]
}